# =============================================================================
# TCL Ticket API — environment variables
# Copy to `.env` in the project root (same folder as `pyproject.toml`).
# Pydantic reads these as UPPER_SNAKE_CASE matching each setting name below.
# Never commit `.env` with real secrets (see `.gitignore`).
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Human-readable name (OpenAPI title).
APP_NAME="TCL Ticket API"

# true = SQL echo, more verbose stack traces in logs (dev only).
DEBUG=false

# -----------------------------------------------------------------------------
# Database (async SQLAlchemy + asyncmy for MySQL 8+)
# -----------------------------------------------------------------------------
# Format: mysql+asyncmy://USER:PASSWORD@HOST:PORT/DATABASE
# Special characters in USER or PASSWORD must be URL-encoded (e.g. @ -> %40).
#
# Local MySQL on this machine:
# DATABASE_URL=mysql+asyncmy://app:yourpassword@127.0.0.1:3306/TestDB
#
# Docker Compose (service name `db` from the same compose network):
# DATABASE_URL=mysql+asyncmy://app:appsecret@db:3306/TestDB
DATABASE_URL=mysql+asyncmy://app:appsecret@127.0.0.1:3306/TestDB

# -----------------------------------------------------------------------------
# JWT (Authorization: Bearer …)
# -----------------------------------------------------------------------------
# Strong random secret for signing tokens (e.g. `openssl rand -hex 32`).
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32-in-real-deployments

# Algorithm for python-jose (keep default unless you know you need RS256 + keys).
JWT_ALGORITHM=HS256

# Access token lifetime in minutes for POST /auth/token.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# Demo credentials (POST /auth/token, form: username, password)
# -----------------------------------------------------------------------------
# Replace with a real user store / IdP in production.
DEMO_USERNAME=demo
DEMO_PASSWORD=demo

# -----------------------------------------------------------------------------
# Auth gate for /tickets*
# -----------------------------------------------------------------------------
# true  = require valid JWT on ticket routes.
# false = skip bearer check (local smoke tests only; do not use in shared envs).
ENABLE_AUTH=true

# -----------------------------------------------------------------------------
# CORS (browser clients)
# -----------------------------------------------------------------------------
# JSON array (pydantic-settings parses list fields as JSON from .env).
# Use ["*"] only in development.
CORS_ORIGINS=["*"]

# Comma-separated string is also accepted by the app validator:
# CORS_ORIGINS=http://localhost:3000,https://app.example.com

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# true = compact JSON-ish lines (basic formatter); false = human-readable lines.
LOG_JSON=false

# -----------------------------------------------------------------------------
# Rate limiting (SlowAPI — ticket routes)
# -----------------------------------------------------------------------------
# Syntax: "<count>/<period>" e.g. 60/minute, 1000/hour, 10/second
# POST/PUT use RATE_LIMIT_DEFAULT; GET uses RATE_LIMIT_BURST (higher read ceiling).
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_BURST=120/minute
